{\n  "$schema": "https://json-schema.org/draft/2020-12/schema",\n  "title": "Events Array Schema",\n  "type": "array",\n  "items": {\n    "type": "object",\n    "properties": {\n      "id": { "type": "string" },\n      "stageId": { "type": "string" },\n      "date": { "type": "string", "format": "date" },\n      "time": { \n        "type": "string", \n        "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",\n        "description": "Time in HH:MM format"\n      },\n      "title": { "type": "string" },\n      "presenter": { "type": "string" }\n    },\n    "required": ["id", "stageId", "date", "time", "title", "presenter"]\n  }\n}