{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Events Array Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "stageId": { "type": "string" },
      "date": { "type": "string", "format": "date" },
      "time": { 
        "type": "string", 
        "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
        "description": "Time in HH:MM format"
      },
      "title": { "type": "string" },
      "presenter": { "type": "string" }
    },
    "required": ["id", "stageId", "date", "time", "title", "presenter"]
  }
}