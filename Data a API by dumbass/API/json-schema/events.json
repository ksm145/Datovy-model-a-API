{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Events Array Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "stageId": { "type": "string" },
      "title": { "type": "string" },
      "presenter": { "type": "string" },
      "time": { "type": "string" }
    },
    "required": ["id", "stageId", "title", "presenter", "time"]
  }
}