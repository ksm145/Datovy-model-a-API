{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performers Array Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string" },
      "company": { "type": "string" },
      "category": { "type": "string" },
      "website": { "type": "string" }
    },
    "required": ["id", "name", "company", "category", "website"]
  }
}